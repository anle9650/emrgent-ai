# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# --- OpenEMR OAuth2 / API ---
# OIDC issuer = OpenEMR oauth2 base for the site (Auth.js fetches
# {OPENEMR_ISSUER}/.well-known/openid-configuration for discovery).
OPENEMR_ISSUER=https://localhost:9300/oauth2/default
# Register a client at {OPENEMR_ISSUER}/registration with redirect_uri
# http://localhost:3000/api/auth/callback/openemr, then enable it
# (Administration -> System -> API Clients) before it can authenticate.
OPENEMR_CLIENT_ID=****
OPENEMR_CLIENT_SECRET=****
# Standard REST API base (FHIR base is .../apis/default/fhir)
OPENEMR_API_BASE=https://localhost:9300/apis/default
# DEV ONLY: accept OpenEMR's self-signed cert on :9300. Never set in production.
OPENEMR_ALLOW_SELF_SIGNED=true
# Demo mode: when true, any session that isn't OpenEMR-connected (guests too) is
# served a consistent, per-user stateful mock OpenEMR instead of the "connect to
# OpenEMR" flow — so the app can be demoed end-to-end with no real OpenEMR
# server. Leave unset in real deployments. Ignored under the Playwright/eval
# fixture path.
OPENEMR_DEMO=true

# --- Merge Agent Handler (MCP) ---
# Optional. When all three are set, the agent gets NPI Registry provider search
# (search_individual_providers) over MCP. If any is missing, it's silently
# skipped. Create the API key + Tool Pack at https://ah.merge.dev and one shared
# Registered User (its UUID) — NPI data is public, so no per-user auth is needed.
MERGE_AGENT_HANDLER_API_KEY=****
MERGE_TOOL_PACK_ID=****
MERGE_REGISTERED_USER_ID=****
